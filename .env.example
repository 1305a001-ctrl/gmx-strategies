REDIS_URL=redis://localhost:6379/0

CHAINS_ENABLED=arbitrum
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Markets to monitor (must match chainlink-streams aliases)
MONITORED_MARKETS=btc,eth,sol,wsteth

# Liquidation triggering
LIQUIDATION_WATCH_MARGIN=1.05
ESTIMATED_KEEPER_FEE_USD=100.0

# Funding rate arb
FUNDING_ARB_MIN_RATE=0.0005
FUNDING_ARB_MAX_POSITION_USD=50000
FUNDING_ARB_HEDGE_VENUE=binance
FUNDING_ARB_POLL_INTERVAL_S=60
FUNDING_ARB_SIGNALS_CHANNEL=funding_arb:signals
FUNDING_ARB_EVAL_LOG_STREAM=funding_arb:eval_log
FUNDING_ARB_EVAL_LOG_MAXLEN=1000000

# Pool imbalance
POOL_IMBALANCE_MIN_PP=0.10

# Eval log
PAPER_LOG_STREAM=gmx:eval_log
PAPER_LOG_MAXLEN=5000000

# Live execution gates
LIVE_ENABLED=false
LIVE_STRATEGIES_CONFIRMED=
EXECUTOR_PRIVATE_KEY=
MAX_POSITION_USD=5000
MAX_CONCURRENT_POSITIONS=3

HTTP_HOST=0.0.0.0
HTTP_PORT=8013
LOG_LEVEL=INFO
